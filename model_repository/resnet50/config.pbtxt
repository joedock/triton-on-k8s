name: "resnet50"
platform: "pytorch_libtorch"
max_batch_size: 8

input [
  {
    name: "input__0"
    data_type: TYPE_FP32
    dims: [ 3, 224, 224 ]
  }
]

output [
  {
    name: "output__0"
    data_type: TYPE_FP32
    dims: [ 1000 ]
  }
]

instance_group [
  {
    count: 1
    kind: KIND_CPU
  }
]

dynamic_batching {
  preferred_batch_size: [ 4, 8 ]
  # max_queue_delay_microseconds: 2000
  # Chosen based on benchmark data (May 6 2026):
  # 100us → 1.09x batching ratio
  # 2000us → 2.67x batching ratio  
  # 5000us → 2.67x batching ratio (no additional gain over 2000us)
  # 2000us selected as optimal — maximum batching benefit with minimum queue latency.
  max_queue_delay_microseconds: 2000
}
